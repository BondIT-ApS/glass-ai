{
  "name": "glass-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Even Realities G2 smart glasses app — bridges to Hermes AI via OpenAI-compatible HTTP API.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
