# GlassAI configuration — copy to .env.local and fill in values.
# Vite exposes any VITE_-prefixed var to the browser bundle. Anything sensitive
# must NOT live here for production builds — use the in-app settings screen
# (stored via the SDK's setLocalStorage on the companion phone) instead.

# Default Hermes proxy endpoint. The in-app settings screen overrides this at runtime.
VITE_HERMES_DEFAULT_ENDPOINT=https://glassai.bondit.dk

# Default model — Hermes proxies to whichever underlying model this resolves to.
VITE_HERMES_DEFAULT_MODEL=gpt-4o-mini

# Build metadata
VITE_APP_NAME=GlassAI
VITE_APP_PACKAGE_ID=com.bondit.glassai
